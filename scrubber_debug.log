3 | import (
4 | 	"context"
5 | 	"encoding/json"
6 | 	"fmt"
7 | 	"os"
8 | 	"strings"
9 | 
10 | 	"github.com/user/armage/pkg/provider"
11 | )
12 | 
13 | type AgentStatus string
14 | 
15 | const (
16 | 	StatusRunning AgentStatus = "running"
17 | 	StatusPending AgentStatus = "pending" // Waiting for approval
18 | )
19 | 
20 | // StepResult contains the outcome of a single turn.
21 | type StepResult struct {
22 | 	Thought   string         `json:"thought"`
23 | 	Status    AgentStatus    `json:"status"`
24 | 	ToolCalls []ToolCall     `json:"tool_calls,omitempty"`
25 | 	Usage     provider.Usage `json:"usage"`
26 | }
27 | 
28 | // Agent is the core orchestrator.
29 | type Agent struct {
30 | 	LLM             provider.LLM
31 | 	Registry        *Registry
32 | 	History         []provider.Message
33 | 	RequireApproval bool           // Safety Governor flag
34 | 	PendingResult   *StepResult    // Stashed result waiting for approval
35 | 	MaxHistory      int            // Maximum number of messages to keep (0 for unlimited)
36 | 	TotalUsage      provider.Usage // Cumulative token usage
37 | 	PinnedFiles     []string       // List of paths pinned to context
38 | }
39 | 
40 | type State struct {
41 | 	History         []provider.Message `json:"history"`
42 | 	RequireApproval bool               `json:"require_approval"`
43 | 	MaxHistory      int                `json:"max_history"`
44 | 	TotalUsage      provider.Usage     `json:"total_usage"`
45 | 	PinnedFiles     []string           `json:"pinned_files"`
46 | }
47 | 
48 | func New(llm provider.LLM, registry *Registry) *Agent {
49 | 	return &Agent{
50 | 		LLM:         llm,
51 | 		Registry:    registry,
52 | 		History:     []provider.Message{},
53 | 		MaxHistory:  30, 
54 | 		PinnedFiles: []string{},
55 | 	}
56 | }
57 | 
58 | // Save persists the agent's history to disk.
59 | func (a *Agent) Save(path string) error {
60 | 	state := State{
61 | 		History:         a.History,
62 | 		RequireApproval: a.RequireApproval,
63 | 		MaxHistory:      a.MaxHistory,
64 | 		TotalUsage:      a.TotalUsage,
65 | 		PinnedFiles:     a.PinnedFiles,
66 | 	}
67 | 	data, err := json.MarshalIndent(state, "", "  ")
68 | 	if err != nil {
69 | 		return err
70 | 	}
71 | 	return os.WriteFile(path, data, 0644)
72 | }
73 | 
74 | // Load restores the agent's history from disk.
75 | func (a *Agent) Load(path string) error {
76 | 	data, err := os.ReadFile(path)
77 | 	if err != nil {
78 | 		return err
79 | 	}
80 | 	var state State
81 | 	if err := json.Unmarshal(data, &state); err != nil {
82 | 		return err
83 | 	}
84 | 	a.History = state.History
85 | 	a.RequireApproval = state.RequireApproval
86 | 	a.MaxHistory = state.MaxHistory
87 | 	a.TotalUsage = state.TotalUsage
88 | 	a.PinnedFiles = state.PinnedFiles
89 | 	return nil
90 | }
91 | 
92 | // AddSystemPrompt sets the initial context.
93 | func (a *Agent) AddSystemPrompt(prompt string) {
94 | 	a.History = append(a.History, provider.Message{Role: "system", Content: prompt})
95 | }
96 | 
97 | // PinFile adds a file's content permanently to the history (protected from trimming).
98 | func (a *Agent) PinFile(path string) error {
99 | 	data, err := os.ReadFile(path)
100 | 	if err != nil {
101 | 		return err
102 | 	}
103 | 
104 | 	content := fmt.Sprintf("Pinned File: %s\n---\n%s\n---", path, string(data))
105 | 	
106 | 	for _, p := range a.PinnedFiles {
107 | 		if p == path {
108 | 			return nil 
109 | 		}
110 | 	}
111 | 
112 | 	a.PinnedFiles = append(a.PinnedFiles, path)
113 | 	msg := provider.Message{Role: "system", Content: content}
114 | 	
115 | 	if len(a.History) > 0 && a.History[0].Role == "system" && !strings.Contains(a.History[0].Content, "Pinned File:") {
116 | 		newHistory := make([]provider.Message, 0, len(a.History)+1)
117 | 		newHistory = append(newHistory, a.History[0])
118 | 		newHistory = append(newHistory, msg)
119 | 		newHistory = append(newHistory, a.History[1:]...)
120 | 		a.History = newHistory
121 | 	} else {
122 | 		a.History = append([]provider.Message{msg}, a.History...)
123 | 	}
124 | 
125 | 	return nil
126 | }
127 | 
128 | // Step performs a single ReAct turn.
129 | func (a *Agent) Step(ctx context.Context, input string) (StepResult, error) {
130 | 	if input != "" {
131 | 		a.History = append(a.History, provider.Message{Role: "user", Content: input})
132 | 	}
133 | 
134 | 	// 1. Get LLM Response
135 | 	response, usage, err := a.LLM.Chat(ctx, a.History)
136 | 	if err != nil {
137 | 		return StepResult{}, fmt.Errorf("LLM error: %w", err)
138 | 	}
139 | 	a.History = append(a.History, provider.Message{Role: "assistant", Content: response})
140 | 
141 | 	// Track Usage
142 | 	a.TotalUsage.PromptTokens += usage.PromptTokens
143 | 	a.TotalUsage.CompletionTokens += usage.CompletionTokens
144 | 	a.TotalUsage.TotalTokens += usage.TotalTokens
145 | 
146 | 	// 2. Parse Response
147 | 	thought, toolCalls, err := Parse(response)
148 | 	if err != nil {
149 | 		a.trimHistory(ctx) 
150 | 		return StepResult{Thought: thought, Status: StatusRunning, Usage: usage}, nil
151 | 	}
152 | 
153 | 	// 3. Detect if the agent is stuck (Thought but no Action and no Final Answer)
154 | 	isFinished := strings.Contains(strings.ToLower(thought), "final answer")
155 | 	if len(toolCalls) == 0 && !isFinished {
156 | 		res := StepResult{
157 | 			Thought: thought,
158 | 			Status:  StatusRunning, 
159 | 			Usage:   usage,
160 | 		}
161 | 		a.trimHistory(ctx)
162 | 		return res, nil
163 | 	}
164 | 
165 | 	// Limit to 5 calls per turn
166 | 	if len(toolCalls) > 5 {
167 | 		toolCalls = toolCalls[:5]
168 | 	}
169 | 
170 | 	res := StepResult{
171 | 		Thought:   thought,
172 | 		ToolCalls: toolCalls,
173 | 		Status:    StatusRunning,
174 | 		Usage:     usage,
175 | 	}
176 | 
177 | 	// 4. Handle Tool Execution with Safety Governor
178 | 	if len(toolCalls) > 0 {
179 | 		if a.RequireApproval {
180 | 			res.Status = StatusPending
181 | 			a.PendingResult = &res
182 | 			return res, nil
183 | 		}
184 | 		res, err = a.ExecuteTools(ctx, res)
185 | 	}
186 | 
187 | 	a.trimHistory(ctx)
188 | 	return res, err
189 | }
190 | 
191 | // StepTransient sends a message to the LLM without adding it to the history.
192 | func (a *Agent) StepTransient(ctx context.Context, instruction string) (StepResult, error) {
193 | 	tempHistory := make([]provider.Message, len(a.History))
194 | 	copy(tempHistory, a.History)
195 | 	tempHistory = append(tempHistory, provider.Message{Role: "user", Content: instruction})
196 | 
197 | 	response, usage, err := a.LLM.Chat(ctx, tempHistory)
198 | 	if err != nil {
199 | 		return StepResult{}, err
200 | 	}


