220 | func (a *Agent) trimHistory(ctx context.Context) {
221 | 	if a.MaxHistory <= 0 || len(a.History) <= a.MaxHistory {
222 | 		return
223 | 	}
224 | 
225 | 	prefixCount := 0
226 | 	for _, msg := range a.History {
227 | 		if msg.Role == "system" {
228 | 			prefixCount++
229 | 		} else {
230 | 			break
231 | 		}
232 | 	}
233 | 
234 | 	keepCount := a.MaxHistory - (prefixCount + 1)
235 | 	if keepCount < 2 {
236 | 		keepCount = 2
237 | 	}
238 | 
239 | 	startIdx := len(a.History) - keepCount
240 | 	if startIdx <= prefixCount {
241 | 		return 
242 | 	}
243 | 
244 | 	turnsToSummarize := a.History[prefixCount:startIdx]
245 | 	summary, err := a.summarize(ctx, turnsToSummarize)
246 | 	if err == nil {
247 | 		summaryMsg := provider.Message{
248 | 			Role:    "system",
249 | 			Content: fmt.Sprintf("Previous Conversation Summary: %s", summary),
250 | 		}
251 | 		
252 | 		newHistory := make([]provider.Message, 0, a.MaxHistory)
253 | 		newHistory = append(newHistory, a.History[:prefixCount]...)
254 | 		newHistory = append(newHistory, summaryMsg)
255 | 		newHistory = append(newHistory, a.History[startIdx:]...)
256 | 		a.History = newHistory
257 | 	} else {
258 | 		newHistory := make([]provider.Message, 0, a.MaxHistory)
259 | 		newHistory = append(newHistory, a.History[:prefixCount]...)
260 | 		newHistory = append(newHistory, a.History[startIdx:]...)
261 | 		a.History = newHistory
262 | 	}
263 | }
264 | 
265 | func (a *Agent) summarize(ctx context.Context, messages []provider.Message) (string, error) {
266 | 	if len(messages) == 0 {
267 | 		return "", nil
268 | 	}
269 | 
270 | 	prompt := []provider.Message{
271 | 		{Role: "system", Content: "Summarize the following conversation turns concisely (max 2 sentences). Focus on what was achieved. Do NOT return an empty response. End with 'SUMMARY: [your summary]'."},
272 | 	}
273 | 	prompt = append(prompt, messages...)
274 | 
275 | 	summary, _, err := a.LLM.Chat(ctx, prompt)
276 | 	if err != nil {
277 | 		return "", err
278 | 	}
279 | 
280 | 	if parts := strings.Split(summary, "SUMMARY:"); len(parts) > 1 {
281 | 		return strings.TrimSpace(parts[len(parts)-1]), nil
282 | 	}
283 | 
284 | 	return summary, nil
285 | }
286 | 
287 | // Approve continues the execution of pending tool calls.
288 | func (a *Agent) Approve(ctx context.Context) (StepResult, error) {
289 | 	if a.PendingResult == nil {
290 | 		return StepResult{}, fmt.Errorf("no pending action to approve")
291 | 	}
292 | 	res := *a.PendingResult
293 | 	a.PendingResult = nil
294 | 	res, err := a.ExecuteTools(ctx, res)
295 | 	a.trimHistory(ctx)
296 | 	return res, err
297 | }
