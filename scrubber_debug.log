58 | // Save persists the agent's history to disk.
59 | func (a *Agent) Save(path string) error {
60 | 	state := State{
61 | 		History:         a.History,
62 | 		RequireApproval: a.RequireApproval,
63 | 		MaxHistory:      a.MaxHistory,
64 | 		TotalUsage:      a.TotalUsage,
65 | 		PinnedFiles:     a.PinnedFiles,
66 | 	}
67 | 	data, err := json.MarshalIndent(state, "", "  ")
68 | 	if err != nil {
69 | 		return err
70 | 	}
71 | 	return os.WriteFile(path, data, 0644)
72 | }
