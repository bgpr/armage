```go
package main

import (
    "bytes"
    "encoding/json"
    "fmt"
    "log"
)

// Output represents the output of the command
type Output struct {
    Commands []string
}

func (o *Output) ToJSON() []byte {
    jsonBytes, err := json.Marshal(o)
    if err != nil {
        log.Fatal(err)
    }
    return jsonBytes
}

func main() {
    // Assume the following command
    output := &Output{
        Commands: []string{
            "echo Command1",
            "echo Command2",
        },
    }

    // Refactor the command to output everything as a JSON object
    var buf bytes.Buffer
    jsonOutput := output.ToJSON()
    buf.Write(jsonOutput)

    // Print the JSON output
    fmt.Println("---SAFE---")
    fmt.Println(buf.String())
    fmt.Println("---END---")
}
```

